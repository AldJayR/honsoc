{
	"compilerOptions": {
		"target": "es2025",
		"lib": ["es2025", "dom"],
		"allowImportingTsExtensions": true,
		"module": "preserve",
		"moduleResolution": "bundler",
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,
		"noEmit": true,
		"verbatimModuleSyntax": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": ["src"]
}
